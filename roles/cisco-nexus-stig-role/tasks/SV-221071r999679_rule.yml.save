# DISA STIG:
#   SRG-NET-000018-RTR-000001
#   Severity: medium
#   Rule ID: SV-221071r999679_rule
#   Identifiers: SV-110961, V-101857, CCI-001368
#   Title: The Cisco switch must enforce information flow control using ACLs.#


# This task creates the ACL (EXTERNAL_MGMT_ACL) and applies it to mgmt0.

- name: "[SV-221071r999679_rule] Configure {{ external_mgmt_acl_name }} with required flow rules"
  cisco.nxos.nxos_acl:
    config:
      - name: "{{ external_mgmt_acl_name }}"
        sequence:
          - 10:
              action: permit
              protocol: tcp
              src: "{{ external_mgmt_allowed_subnet }}"
              dest: any
              dport: "{{ external_mgmt_allowed_ports }}"
          - 20:
              action: "{{ 'permit' if external_mgmt_allow_icmp else 'deny' }}"
              protocol: icmp
              src: any
              dest: any
          - 90:
              action: deny
              protocol: ip
              src: any
              dest: any
  loop: "{{ external_mgmt_allowed_tcp_ports }}"
  when: sv_221071r999679_rule_enabled

- name: "[SV-221071r999679_rule] Apply {{ external_mgmt_acl_name }} to mgmt0 interface"
  cisco.nxos.nxos_interfaces:
    config:
      - name: mgmt0
        ipv4:
          access_group:
            in: "{{ external_mgmt_acl_name }}"
  when: sv_221071r999679_rule_enabled
